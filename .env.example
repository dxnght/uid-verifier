# ── Telegram ──────────────────────────────────────────────────────────────
# Required. Get from @BotFather → /newbot
BOT_TOKEN=

# Optional. Username without @, e.g. my_verifier_bot
# Used to build deep-link URLs in /start flow
BOT_USERNAME=

# ── Supabase ───────────────────────────────────────────────────────────────
# Required. Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=

# Required. service_role key (not anon!). Same location.
# Never expose this to the client — server-side only.
SUPABASE_SERVICE_ROLE_KEY=

# ── Upstash Redis (optional) ───────────────────────────────────────────────
# Used for rate limiting and caching. Leave empty to disable.
# Get from upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Anthropic Claude (optional) ────────────────────────────────────────────
# Used for AI features. Leave empty to disable.
ANTHROPIC_API_KEY=
# Default: claude-sonnet-4-5. Override only if you need a specific model.
ANTHROPIC_MODEL=

# ── Bot operators ──────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs with global admin access.
# Example: 123456789,987654321
OPERATOR_IDS=

# ── Demo community ─────────────────────────────────────────────────────────
# UUID of a community to use in DM when user arrives without a deep-link.
# Get from Supabase after running 0001_init.sql and creating a community row.
DEFAULT_COMMUNITY_ID=

# ── Webhook (production only) ──────────────────────────────────────────────
# Leave empty locally → bot runs in polling mode.
# On Render: set to your service domain, e.g. https://uid-verifier.onrender.com
WEBHOOK_DOMAIN=

# Optional shared secret between Render and Telegram to validate webhook calls.
WEBHOOK_SECRET=

# HTTP port for the webhook server. Render injects PORT automatically.
PORT=3000

# ── Runtime ────────────────────────────────────────────────────────────────
# development | production
NODE_ENV=development

# Log verbosity (not wired to a logger yet, reserved for future use)
LOG_LEVEL=info
